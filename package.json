{
  "name": "ml-gestao-total",
  "version": "1.0.0",
  "description": "Plataforma unificada de gestão de RH e Operações com interconexão via CPF",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "node scripts/dev-server.cjs",
    "dev:client": "vite",
    "build": "vite build",
    "build:server": "node node_modules/typescript/bin/tsc -p tsconfig.server.runtime.json",
    "check:server": "node node_modules/typescript/bin/tsc -p tsconfig.server.json --noEmit",
    "prestart": "pnpm run build:server",
    "start": "node server-dist/server/core/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "pnpm run test:client && pnpm run test:server",
    "test:client": "vitest run --passWithNoTests",
    "test:server": "vitest run --config vitest.server.config.ts",
    "test:auth": "vitest run --config vitest.server.config.ts server/routes/auth.http.test.ts server/routes/auth.flows.test.ts",
    "validate": "pnpm run check && pnpm run check:server && pnpm run build:server && pnpm run build && pnpm run test",
    "validate:full": "pnpm run validate && pnpm run smoke:local",
    "smoke": "bash deployment/linux/smoke-test.sh",
    "smoke:local": "bash scripts/smoke-local.sh",
    "ops:check": "bash deployment/linux/ops-check.sh",
    "backup:sqlite": "bash deployment/linux/backup-sqlite.sh",
    "db:push": "drizzle-kit generate && drizzle-kit migrate"
  },
